{
  "name": "starlight-theme-exquisitus",
  "version": "1.1.0",
  "license": "MIT",
  "description": "An Astro Starlight theme where readability and beauty are the same discipline.",
  "author": "Anaxite",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anaxite/starlight-theme-exquisitus.git",
    "directory": "packages/starlight-theme-exquisitus"
  },
  "homepage": "https://github.com/anaxite/starlight-theme-exquisitus",
  "bugs": "https://github.com/anaxite/starlight-theme-exquisitus/issues",
  "exports": {
    ".": "./index.ts",
    "./components/FeatureGrid.astro": "./components/FeatureGrid.astro",
    "./components/SpecimenPlate.astro": "./components/SpecimenPlate.astro",
    "./overrides/Hero.astro": "./overrides/Hero.astro",
    "./styles/fonts": "./styles/fonts.css",
    "./styles/layers": "./styles/layers.css",
    "./styles/tokens": "./styles/tokens.css",
    "./styles/base": "./styles/base.css",
    "./styles/prose": "./styles/prose.css",
    "./styles/end-mark": "./styles/end-mark.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "biome format --write"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/literata": "^5.2.8",
    "@fontsource/alegreya-sans": "^5.2.8"
  },
  "files": [
    "CHANGELOG.md",
    "index.ts",
    "components/",
    "libs/",
    "overrides/",
    "styles/"
  ],
  "peerDependencies": {
    "@astrojs/starlight": ">=0.41.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "warn"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "starlight",
    "starlight-theme",
    "theme",
    "plugin",
    "astro",
    "documentation",
    "accessibility",
    "typography"
  ]
}
